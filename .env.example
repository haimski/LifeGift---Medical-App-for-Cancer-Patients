# Required — server-side only, never exposed to the client (see lib/llm/client.ts).
ANTHROPIC_API_KEY=

# Optional — override the default models without touching code.
# Defaults: claude-haiku-4-5-20251001 (extraction), claude-sonnet-5 (phrasing).
LIFEGIFT_EXTRACTION_MODEL=
LIFEGIFT_PHRASING_MODEL=

# Required for Phase 7+ persistence — Vercel Postgres (Neon-backed) connection
# string, used via Neon's serverless driver adapter (see lib/db/prisma.ts).
# Create the Postgres store from the Vercel dashboard so this auto-injects
# into the project; for local dev, copy it from Vercel's project settings.
DATABASE_URL=
